{
  "meta": {
    "version": "1.2.0",
    "description": "Только запрещённый Twitch контент: hate speech, slurs, угрозы, CSAM. Без обычного мата.",
    "action": "auto_ban"
  },
  "normalization": {
    "lowercase": true,
    "strip_zero_width": true,
    "collapse_repeated_chars_max": 2,
    "replace_leetspeak": {
      "0": "o", "1": "i", "3": "e", "4": "a", "5": "s",
      "6": "g", "7": "t", "8": "b", "9": "g",
      "@": "a", "$": "s", "!": "i", "|": "i", "€": "e"
    },
    "homoglyph_map": {
      "а": "a", "б": "b", "в": "v", "г": "g", "д": "d", "е": "e", "ё": "e",
      "ж": "zh", "з": "z", "и": "i", "й": "y", "к": "k", "л": "l", "м": "m",
      "н": "n", "о": "o", "п": "p", "р": "r", "с": "c", "т": "t", "у": "u",
      "ф": "f", "х": "h", "ц": "c", "ч": "ch", "ш": "sh", "щ": "sch",
      "ъ": "", "ы": "y", "ь": "", "э": "e", "ю": "yu", "я": "ya",
      "і": "i", "ї": "i", "є": "e", "ґ": "g"
    },
    "remove_chars": [
      " ", ".", ",", "-", "_", "*", "+", "|", "/", "\\", "'", "\"", "`", "~",
      "(", ")", "[", "]", "{", "}", "·", "•", "‒", "–", "—", ":", ";", "!"
    ]
  },
  "categories": {
    "homophobic_transphobic_ru": {
      "label": "гомофобия_трансфобия_ру",
      "severity": "critical",
      "action": "instant_ban",
      "comment": "Twitch: hateful conduct / slurs (sexual orientation, gender identity)",
