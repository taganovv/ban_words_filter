        "пидор", "пидора", "пидоры", "пидорский", "пидорская", "пидорство",
        "пидорок", "пидоришка", "пидорюга", "пидорина", "пидорятина",
        "пидорас", "пидорасы", "пидораска", "пидорасина",
        "пидрила", "пидрило",
        "педик", "педики", "педрила", "педрилы", "педераст", "педерасты",
        "гомик", "гомики", "гомосек", "гомосеки", "гомосятина",
        "трансуха", "лесбуха", "лесбухи",
        "pidor", "pidora", "pidoras", "pidorasy", "pidory", "pidr", "pidorok",
