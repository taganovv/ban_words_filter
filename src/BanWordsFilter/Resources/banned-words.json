      "regex": [
        "p+[iy1!|]+d+[o0]+r+",
        "p+[iy1!|]+d+[o0]+r+[aа4]+s+",
        "p+[iy1!|]+d+[o0]+r+[aа4]+s+[iy1!|]+n+[aа4]+",
        "p+[iy1!|]+d+[o0]+r+[iy1!|]+n+[aа4]+",
        "p+[iy1!|]+d+r+[iy1!|]+l+[aа4]+",
        "p+[иi1!|y]+d+[o0дd]+[o0рr]+",
        "p+[иi1!|y]+d+[o0дd]+[o0рr]+[aа4]+s+",
        "p+[иi1!|y]+d+[o0дd]+[o0рr]+[aа4]+s+[iy1!|]+n+[aа4]+",
        "p+[e3]+d+[iy1!|]+[kк]+",
        "p+[e3]+d+r+[iy1!|]+l+[aа4]+",
        "g+[o0]+m+[iy1!|]+[kк]+",
