<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Styles.Resources>
    <SolidColorBrush x:Key="BgBrush" Color="#0E0E10" />
    <SolidColorBrush x:Key="PanelBrush" Color="#18181B" />
    <SolidColorBrush x:Key="BorderBrush" Color="#2D2D32" />
    <SolidColorBrush x:Key="TextBrush" Color="#EFEFF1" />
    <SolidColorBrush x:Key="MutedBrush" Color="#ADADB8" />
    <SolidColorBrush x:Key="PurpleBrush" Color="#9146FF" />
    <SolidColorBrush x:Key="PurpleHoverBrush" Color="#772CE8" />
    <SolidColorBrush x:Key="GreenBrush" Color="#00F593" />
    <SolidColorBrush x:Key="RedBrush" Color="#EB0400" />
    <SolidColorBrush x:Key="InputBrush" Color="#1F1F23" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="#3A3A3D" />
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource BgBrush}" />
    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    <Setter Property="FontFamily" Value="Inter, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif" />
    <Setter Property="Icon" Value="/Assets/app-icon.png" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Cursor" Value="Hand" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="20" />
  </Style>

  <Style Selector="TextBox, ComboBox">
    <Setter Property="Background" Value="{StaticResource InputBrush}" />
    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="10,8" />
  </Style>

  <Style Selector="Button.tab">
    <Setter Property="Background" Value="{StaticResource PanelBrush}" />
    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="8,10" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.tab.nav">
    <Setter Property="Width" Value="128" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.tab.active">
    <Setter Property="Background" Value="{StaticResource PurpleBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource PurpleBrush}" />
    <Setter Property="Foreground" Value="White" />
  </Style>

  <Style Selector="Button.tab.active:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource PurpleHoverBrush}" />
  </Style>

  <Style Selector="Button.tab:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#303035" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{StaticResource PurpleBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="10,12" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource PurpleHoverBrush}" />
  </Style>

  <Style Selector="Button.secondary">
    <Setter Property="Background" Value="{StaticResource SecondaryBrush}" />
    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="10,12" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.compact">
    <Setter Property="Padding" Value="14,7" />
    <Setter Property="MinHeight" Value="34" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="ProgressBar.thin">
    <Setter Property="Height" Value="4" />
    <Setter Property="MinHeight" Value="4" />
    <Setter Property="MaxHeight" Value="4" />
    <Setter Property="Foreground" Value="{StaticResource PurpleBrush}" />
    <Setter Property="Background" Value="{StaticResource BorderBrush}" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <Style Selector="Button.danger">
    <Setter Property="Background" Value="{StaticResource RedBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="10,12" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.link">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource PurpleBrush}" />
    <Setter Property="Padding" Value="0,0,0,0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="Button.link:pointerover /template/ ContentPresenter">
    <Setter Property="Foreground" Value="{StaticResource PurpleHoverBrush}" />
  </Style>

  <Style Selector="Button.resource">
    <Setter Property="Background" Value="#262629" />
    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="12,10" />
  </Style>

  <Style Selector="Button.resource:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#303035" />
  </Style>

  <Style Selector="Button.reveal">
    <Setter Property="Background" Value="{StaticResource InputBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="MinWidth" Value="40" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Button.reveal:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#303035" />
  </Style>

  <Style Selector="Button.reveal:pointerover Path">
    <Setter Property="Fill" Value="{StaticResource TextBrush}" />
  </Style>

  <Style Selector="Button.reveal:pointerover Line">
    <Setter Property="Stroke" Value="{StaticResource TextBrush}" />
  </Style>

  <Style Selector="Button.donate">
    <Setter Property="Background" Value="#C8960C" />
    <Setter Property="Foreground" Value="#1A1200" />
    <Setter Property="BorderBrush" Value="#FFD700" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="12,10" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="ClipToBounds" Value="True" />
    <Style.Animations>
      <Animation Duration="0:0:1.6"
                 IterationCount="INfinite"
                 PlaybackDirection="Alternate">
        <KeyFrame Cue="0%">
          <Setter Property="Background" Value="#B8860B" />
          <Setter Property="BorderBrush" Value="#FFD700" />
        </KeyFrame>
        <KeyFrame Cue="100%">
          <Setter Property="Background" Value="#FFD54F" />
          <Setter Property="BorderBrush" Value="#FFF8B0" />
        </KeyFrame>
      </Animation>
    </Style.Animations>
  </Style>

  <Style Selector="Button.donate:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#FFE082" />
  </Style>

  <Style Selector="Button.donate Border.donate-shine">
    <Setter Property="Width" Value="36" />
    <Setter Property="Height" Value="24" />
    <Setter Property="Opacity" Value="0.65" />
    <Setter Property="IsHitTestVisible" Value="False" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="RenderTransformOrigin" Value="50%,50%" />
    <Setter Property="RenderTransform" Value="rotate(-20deg)" />
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#00FFFFFF" Offset="0" />
        <GradientStop Color="#CCFFFFFF" Offset="0.5" />
        <GradientStop Color="#00FFFFFF" Offset="1" />
      </LinearGradientBrush>
    </Setter>
    <Style.Animations>
      <Animation Duration="0:0:2.4"
                 IterationCount="INfinite">
        <KeyFrame Cue="0%">
          <Setter Property="TranslateTransform.X" Value="-48" />
          <Setter Property="Opacity" Value="0" />
        </KeyFrame>
        <KeyFrame Cue="15%">
          <Setter Property="Opacity" Value="0.75" />
        </KeyFrame>
        <KeyFrame Cue="85%">
          <Setter Property="Opacity" Value="0.75" />
        </KeyFrame>
        <KeyFrame Cue="100%">
          <Setter Property="TranslateTransform.X" Value="96" />
          <Setter Property="Opacity" Value="0" />
        </KeyFrame>
      </Animation>
    </Style.Animations>
  </Style>

  <Style Selector="Border.status">
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="16,14" />
    <Setter Property="Background" Value="#1F1F23" />
    <Setter Property="BorderBrush" Value="{StaticResource MutedBrush}" />
  </Style>

  <Style Selector="Border.status-panel">
    <Setter Property="MinHeight" Value="140" />
    <Setter Property="Padding" Value="22,20" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="Ellipse.status-indicator">
    <Setter Property="Width" Value="64" />
    <Setter Property="Height" Value="64" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.status-text">
    <Setter Property="FontSize" Value="32" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.action">
    <Setter Property="Width" Value="208" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.status.running">
    <Setter Property="Background" Value="#142820" />
    <Setter Property="BorderBrush" Value="{StaticResource GreenBrush}" />
  </Style>

  <Style Selector="TextBox.log, TextBox.result">
    <Setter Property="Background" Value="{StaticResource InputBrush}" />
    <Setter Property="AcceptsReturn" Value="True" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="IsReadOnly" Value="True" />
    <Setter Property="FontFamily" Value="Consolas, SF Mono, Menlo, monospace" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Height" Value="360" />
  </Style>
</Styles>
