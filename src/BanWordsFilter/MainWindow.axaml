<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BanWordsFilter.ViewModels"
        xmlns:models="using:BanWordsFilter.Models"
        xmlns:conv="using:BanWordsFilter.Converters"
        x:Class="BanWordsFilter.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Ban Words Filter"
        Width="980"
        Height="760"
        MinWidth="820"
        MinHeight="640"
        WindowStartupLocation="CenterScreen">

  <Window.Resources>
    <conv:IntEqualsConverter x:Key="IntEquals" />
    <conv:BoolToBrushConverter x:Key="BoolToBrush" />
    <conv:BoolToPasswordCharConverter x:Key="BoolToPasswordChar" />
    <conv:StringNotEmptyConverter x:Key="StringNotEmpty" />
  </Window.Resources>

  <Grid Margin="24,20">
    <Grid RowDefinitions="Auto,Auto,*,Auto">

      <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
        <TextBlock Grid.Column="0"
                   Text="Ban Words Filter"
                   FontSize="24"
                   FontWeight="Bold"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1"
                Classes="secondary"
                Content="Инструкция"
                VerticalAlignment="Center"
                Command="{Binding InstructionsCommand}" />
      </Grid>

      <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
        <Button Classes="tab nav"
                Classes.active="{Binding SelectedTab, Converter={StaticResource IntEquals}, ConverterParameter=0}"
                Content="Настройки"
                Command="{Binding SelectSettingsCommand}" />
        <Button Classes="tab nav"
                Classes.active="{Binding SelectedTab, Converter={StaticResource IntEquals}, ConverterParameter=1}"
                Content="Тест фильтра"
                Command="{Binding SelectTestCommand}" />
        <Button Classes="tab nav"
                Classes.active="{Binding SelectedTab, Converter={StaticResource IntEquals}, ConverterParameter=3}"
                Content="Словари"
                Command="{Binding SelectWordListsCommand}" />
        <Button Classes="tab nav"
                Classes.active="{Binding SelectedTab, Converter={StaticResource IntEquals}, ConverterParameter=4}"
                Content="Баны"
                Command="{Binding SelectBansCommand}" />
        <Button Classes="tab nav"
                Classes.active="{Binding SelectedTab, Converter={StaticResource IntEquals}, ConverterParameter=2}"
                Content="Логи"
                Command="{Binding SelectLogCommand}" />
      </StackPanel>

      <Grid Grid.Row="2">
        <Border Classes="panel" IsVisible="{Binding SelectedTab, Converter={StaticResource IntEquals}, ConverterParameter=0}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14">
              <ItemsControl ItemsSource="{Binding Fields}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:SettingFieldViewModel">
                    <StackPanel Spacing="4" Margin="0,0,0,10">
                      <TextBlock Classes="muted" FontSize="13" Text="{Binding Label}" />
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding Value, Mode=TwoWay}"
                                 PasswordChar="{Binding IsMasked, Converter={StaticResource BoolToPasswordChar}}" />
                        <Button Grid.Column="1"
                                Classes="reveal"
                                Command="{Binding ToggleRevealCommand}"
                                IsVisible="{Binding ShowRevealToggle}"
                                Margin="8,0,0,0"
                                ToolTip.Tip="Показать или скрыть значение">
                          <Viewbox Width="18" Height="18">
                            <Canvas Width="24" Height="24">
                              <Path IsVisible="{Binding IsRevealed}"
                                    Fill="{StaticResource MutedBrush}"
                                    Data="M12,4.5 C7,4.5 2.73,7.61 1,12 C2.73,16.39 7,19.5 12,19.5 C17,19.5 21.27,16.39 23,12 C21.27,7.61 17,4.5 12,4.5 Z M12,16.5 C9.52,16.5 7.5,14.48 7.5,12 C7.5,9.52 9.52,7.5 12,7.5 C14.48,7.5 16.5,9.52 16.5,12 C16.5,14.48 14.48,16.5 12,16.5 Z M12,10.5 C11.17,10.5 10.5,11.17 10.5,12 C10.5,12.83 11.17,13.5 12,13.5 C12.83,13.5 13.5,12.83 13.5,12 C13.5,11.17 12.83,10.5 12,10.5 Z" />
                              <Path IsVisible="{Binding !IsRevealed}"
                                    Fill="{StaticResource MutedBrush}"
                                    Data="M12,4.5 C7,4.5 2.73,7.61 1,12 C2.73,16.39 7,19.5 12,19.5 C17,19.5 21.27,16.39 23,12 C21.27,7.61 17,4.5 12,4.5 Z M12,16.5 C9.52,16.5 7.5,14.48 7.5,12 C7.5,9.52 9.52,7.5 12,7.5 C14.48,7.5 16.5,9.52 16.5,12 C16.5,14.48 14.48,16.5 12,16.5 Z" />
                              <Line IsVisible="{Binding !IsRevealed}"
                                    StartPoint="5,5"
                                    EndPoint="19,19"
                                    Stroke="{StaticResource MutedBrush}"
                                    StrokeThickness="1.8"
                                    StrokeLineCap="Round" />
                            </Canvas>
                          </Viewbox>
                        </Button>
                      </Grid>
                    </StackPanel>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <Grid ColumnDefinitions="Auto,Auto,*"
                    Margin="0,8,0,0">
                <StackPanel Grid.Column="0" Spacing="10">
                  <Button Classes="secondary action"
                          Content="Получить OAuth Token"
                          Command="{Binding OAuthCommand}" />
                  <Button Classes="secondary action"
                          Content="Проверить токен"
                          Command="{Binding ValidateCommand}" />
                  <Button Classes="secondary action"
                          Content="Сохранить"
                          Command="{Binding SaveCommand}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="10"
                            Margin="10,0,0,0">
                  <Button Classes="secondary action"
                          Content="Тест"
                          Command="{Binding ChatTestCommand}" />
                  <Button Classes="action"
                          Content="{Binding BotToggleLabel}"
                          Command="{Binding ToggleBotCommand}"
                          Classes.primary="{Binding !IsRunning}"
                          Classes.danger="{Binding IsRunning}" />
                  <Button Classes="danger action"
                          Content="Очистить все"
                          Command="{Binding ClearAllCommand}" />
                </StackPanel>

                <Border Grid.Column="2"
                        Classes="status status-panel"
                        Classes.running="{Binding IsRunning}"
                        Margin="16,0,0,0">
                  <Grid ColumnDefinitions="Auto,*"
                        VerticalAlignment="Center">
                    <Ellipse Grid.Column="0"
                             Width="28"
                             Height="28"
                             Margin="0,0,16,0"
                             VerticalAlignment="Center"
                             Fill="{Binding IsRunning, Converter={StaticResource BoolToBrush}}" />
                    <TextBlock Grid.Column="1"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Text="{Binding StatusText}" />
                  </Grid>
                </Border>
              </Grid>

              <StackPanel HorizontalAlignment="Center"
                          Margin="0,16,0,0">
                <Border Background="{StaticResource InputBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14,12">
                  <StackPanel Spacing="10"
                              HorizontalAlignment="Center">
                    <TextBlock Text="Development by taganovv"
                               FontSize="15"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Center">
                      <Button Classes="resource" Command="{Binding OpenGithubCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <Border Width="24" Height="24" CornerRadius="6" Background="#24292F">
                            <Path Width="14" Height="14"
                                  Stretch="Uniform"
                                  Fill="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M8,0.5 C3.86,0.5 0.5,3.86 0.5,8 C0.5,11.28 2.69,14.08 5.74,15.03 C6.16,15.1 6.31,14.84 6.31,14.61 C6.31,14.4 6.3,13.88 6.3,13.3 C4.13,13.72 3.64,12.56 3.48,12.08 C3.38,11.81 2.98,11.13 2.62,10.92 C2.32,10.75 1.9,10.36 2.61,10.35 C3.28,10.34 3.77,10.97 3.92,11.25 C4.68,12.59 5.94,12.21 6.35,12.01 C6.41,11.53 6.6,11.21 6.81,11.02 C4.97,10.82 3.03,10.19 3.03,7.36 C3.03,6.52 3.33,5.82 3.83,5.28 C3.76,5.09 3.49,4.29 3.9,3.25 C3.9,3.25 4.59,3.02 6.3,4.01 C6.98,3.84 7.69,3.76 8.4,3.76 C9.11,3.76 9.82,3.84 10.5,4.01 C12.21,3.02 12.9,3.25 12.9,3.25 C13.31,4.29 13.04,5.09 12.97,5.28 C13.47,5.82 13.77,6.52 13.77,7.36 C13.77,10.2 11.83,10.82 9.99,11.02 C10.25,11.25 10.48,11.69 10.48,12.37 C10.48,13.38 10.47,14.19 10.47,14.61 C10.47,14.84 10.62,15.11 11.05,15.03 C14.09,14.08 16.28,11.28 16.28,8 C16.28,3.86 12.92,0.5 8.78,0.5 Z" />
                          </Border>
                          <TextBlock Text="GitHub" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                      </Button>
                      <Button Classes="resource" Command="{Binding OpenTwitchCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <Border Width="24" Height="24" CornerRadius="6" ClipToBounds="True">
                            <Image Source="/Assets/twitch-icon.png"
                                   Width="24"
                                   Height="24"
                                   Stretch="UniformToFill" />
                          </Border>
                          <TextBlock Text="Twitch" VerticalAlignment="Center" FontWeight="SemiBold" />
                        </StackPanel>
                      </Button>
                      <Button Classes="donate" Command="{Binding OpenDonateCommand}">
                        <Panel>
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="24" Height="24" CornerRadius="6" ClipToBounds="True">
                              <Image Source="/Assets/coin-icon.png"
                                     Width="24"
                                     Height="24"
                                     Stretch="UniformToFill" />
                            </Border>
                            <TextBlock Text="Донат" VerticalAlignment="Center" FontWeight="SemiBold" />
                          </StackPanel>
                          <Border Classes="donate-shine" />
                        </Panel>
                      </Button>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <Border Classes="panel" IsVisible="{Binding SelectedTab, Converter={StaticResource IntEquals}, ConverterParameter=1}">
          <StackPanel Spacing="12">
            <TextBlock Classes="muted" Text="Проверка фильтра без Twitch" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBox Grid.Column="0" Margin="0,0,10,0"
                       PlaceholderText="Введите тестовое сообщение..."
                       Text="{Binding TestInput, Mode=TwoWay}" />
              <Button Grid.Column="1" Classes="primary" Content="Проверить" Command="{Binding TestFilterCommand}" />
            </Grid>
            <TextBox Classes="result" Text="{Binding TestResult}" />
          </StackPanel>
        </Border>

        <Border Classes="panel" IsVisible="{Binding SelectedTab, Converter={StaticResource IntEquals}, ConverterParameter=2}">
          <TextBox Classes="log" Text="{Binding LogText}" />
        </Border>

        <Border Classes="panel" IsVisible="{Binding SelectedTab, Converter={StaticResource IntEquals}, ConverterParameter=3}">
          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,14">
              <Button Classes="tab"
                      Classes.active="{Binding WordListSubTab, Converter={StaticResource IntEquals}, ConverterParameter=0}"
                      Content="Чёрный список"
                      Command="{Binding SelectBlacklistCommand}" />
              <Button Classes="tab"
                      Classes.active="{Binding WordListSubTab, Converter={StaticResource IntEquals}, ConverterParameter=1}"
                      Content="Белый список"
                      Command="{Binding SelectWhitelistCommand}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{StaticResource InputBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    Margin="0,0,0,14">
              <StackPanel Spacing="10">
                <TextBlock Classes="muted" Text="Добавить слово или фразу" />
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Grid.Column="0" Margin="0,0,10,0"
                           PlaceholderText="Введите слово..."
                           Text="{Binding NewWordInput, Mode=TwoWay}" />
                  <Button Grid.Column="1" Classes="primary" Content="Добавить" Command="{Binding AddWordCommand}" />
                </Grid>
                <CheckBox IsChecked="{Binding UseAutomaticRegex, Mode=TwoWay}"
                          IsEnabled="{Binding RegexCheckboxEnabled}">
                  <TextBlock Text="Автоматический regex"
                             ToolTip.Tip="{Binding RegexCheckboxTooltip}" />
                </CheckBox>
                <TextBlock Classes="muted"
                           FontSize="12"
                           TextWrapping="Wrap"
                           IsVisible="{Binding ShowRegexHint}"
                           Text="{Binding RegexHintText}" />
              </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource InputBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    Margin="0,0,0,10"
                    IsVisible="{Binding WordListSubTab, Converter={StaticResource IntEquals}, ConverterParameter=0}">
              <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,10,0"
                         PlaceholderText="Поиск по слову, категории или типу (exact / regex)..."
                         Text="{Binding WordListSearch, Mode=TwoWay}" />
                <Button Grid.Row="0" Grid.Column="1"
                        Classes="secondary"
                        Content="Сбросить"
                        Command="{Binding ClearWordListSearchCommand}" />
                <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                  <TextBlock Grid.Column="0"
                             Classes="muted"
                             FontSize="12"
                             VerticalAlignment="Center"
                             Text="{Binding BlacklistCountText}" />
                  <Button Grid.Column="1"
                          Classes="danger"
                          Content="{Binding RemoveSearchRegexButtonText}"
                          IsEnabled="{Binding CanRemoveSearchRegex}"
                          Command="{Binding RemoveAllBlacklistRegexCommand}" />
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource InputBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    Margin="0,0,0,10"
                    IsVisible="{Binding WordListSubTab, Converter={StaticResource IntEquals}, ConverterParameter=1}">
              <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,10,0"
                         PlaceholderText="Поиск по слову или категории..."
                         Text="{Binding WordListSearch, Mode=TwoWay}" />
                <Button Grid.Row="0" Grid.Column="1"
                        Classes="secondary"
                        Content="Сбросить"
                        Command="{Binding ClearWordListSearchCommand}" />
                <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                           Classes="muted"
                           FontSize="12"
                           Margin="0,10,0,0"
                           Text="{Binding WhitelistCountText}" />
              </Grid>
            </Border>

            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                          IsVisible="{Binding WordListSubTab, Converter={StaticResource IntEquals}, ConverterParameter=0}">
              <ItemsControl ItemsSource="{Binding BlacklistEntries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:WordListEntry">
                    <Border Background="{StaticResource InputBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,10"
                            Margin="0,0,0,8">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                          <TextBlock Text="{Binding Text}" FontWeight="SemiBold" TextWrapping="Wrap" />
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Classes="muted" FontSize="12" Text="{Binding Type}" />
                            <TextBlock Classes="muted" FontSize="12" Text="·" />
                            <TextBlock Classes="muted" FontSize="12" Text="{Binding Category}" />
                            <TextBlock Classes="muted"
                                       FontSize="12"
                                       Text="{Binding LinkedWord, StringFormat=→ {0}}"
                                       IsVisible="{Binding LinkedWord, Converter={StaticResource StringNotEmpty}}" />
                          </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="danger"
                                Content="Удалить"
                                VerticalAlignment="Center"
                                Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).RemoveBlacklistEntryCommand}"
                                CommandParameter="{Binding}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                          IsVisible="{Binding WordListSubTab, Converter={StaticResource IntEquals}, ConverterParameter=1}">
              <ItemsControl ItemsSource="{Binding WhitelistEntries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:WordListEntry">
                    <Border Background="{StaticResource InputBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,10"
                            Margin="0,0,0,8">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                          <TextBlock Text="{Binding Text}" FontWeight="SemiBold" TextWrapping="Wrap" />
                          <TextBlock Classes="muted" FontSize="12" Text="{Binding Category}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="danger"
                                Content="Удалить"
                                VerticalAlignment="Center"
                                Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).RemoveWhitelistEntryCommand}"
                                CommandParameter="{Binding}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <TextBlock Grid.Row="4"
                       Classes="muted"
                       FontSize="12"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap"
                       Text="Изменения применяются сразу. Встроенные слова скрываются при удалении, ваши — удаляются полностью." />
          </Grid>
        </Border>

        <Border Classes="panel" IsVisible="{Binding SelectedTab, Converter={StaticResource IntEquals}, ConverterParameter=4}">
          <Grid RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,14">
              <TextBlock Text="{Binding TodayBansHeader}" FontSize="18" FontWeight="SemiBold" />
              <TextBlock Classes="muted" FontSize="13" Text="{Binding TodayBansCountText}" />
              <TextBlock Classes="muted"
                         FontSize="13"
                         TextWrapping="Wrap"
                         IsVisible="{Binding ShowTodayBansEmpty}"
                         Text="{Binding TodayBansEmptyText}" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding TodayBans}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:BanRecord">
                    <Border Background="{StaticResource InputBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,10"
                            Margin="0,0,0,8">
                      <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                          <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="{Binding Username}" FontWeight="Bold" FontSize="16" />
                            <TextBlock Classes="muted" FontSize="12" VerticalAlignment="Center" Text="{Binding BannedAtText}" />
                            <TextBlock Classes="muted" FontSize="12" VerticalAlignment="Center" Text="{Binding ActionLabel}" />
                          </StackPanel>
                          <TextBlock Text="{Binding Reason}" TextWrapping="Wrap" />
                          <TextBlock Classes="muted" FontSize="12" TextWrapping="Wrap"
                                     Text="{Binding Pattern, StringFormat=Совпадение: {0}}" />
                          <TextBlock Classes="muted" FontSize="12" Text="{Binding Category, StringFormat=Категория: {0}}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="secondary"
                                Content="Разбан"
                                VerticalAlignment="Center"
                                Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).UnbanUserCommand}"
                                CommandParameter="{Binding}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Row="3" Margin="0,16,0,0"
              Background="#262629"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12,10"
              IsVisible="{Binding ToastVisible}">
        <TextBlock Text="{Binding ToastMessage}" TextWrapping="Wrap" />
      </Border>
    </Grid>
  </Grid>
</Window>
