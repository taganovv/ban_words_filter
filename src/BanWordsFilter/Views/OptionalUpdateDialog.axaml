<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BanWordsFilter.Views.OptionalUpdateDialog"
        Title="Доступно обновление"
        Width="480"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="Auto,Auto" Margin="24">
    <StackPanel Grid.Row="0" Spacing="12">
      <TextBlock Text="Доступна новая версия"
                 FontSize="18"
                 FontWeight="Bold" />
      <TextBlock x:Name="VersionTextBlock"
                 TextWrapping="Wrap"
                 LineHeight="22" />
      <TextBlock Classes="muted"
                 TextWrapping="Wrap"
                 Text="Рекомендуем обновиться до последней версии, чтобы получить исправления и улучшения." />
    </StackPanel>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10"
                Margin="0,20,0,0">
      <Button Classes="secondary"
              Content="Отмена"
              Click="OnCancelClick" />
      <Button Classes="primary"
              Content="Обновить сейчас"
              Click="OnUpdateClick" />
    </StackPanel>
  </Grid>
</Window>
