<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BanWordsFilter.Views.ConfirmExitDialog"
        Title="Выход"
        Width="460"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="Auto,Auto" Margin="24">
    <StackPanel Grid.Row="0" Spacing="12">
      <TextBlock Text="Выход из программы"
                 FontSize="18"
                 FontWeight="Bold" />
      <TextBlock TextWrapping="Wrap"
                 LineHeight="22"
                 Text="Вы точно хотите полностью закрыть программу?" />
      <TextBlock Classes="muted"
                 TextWrapping="Wrap"
                 Text="Если фильтр запущен, он будет остановлен. Программа закроется полностью и не свернётся в трей." />
    </StackPanel>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10"
                Margin="0,20,0,0">
      <Button Classes="secondary"
              Content="Отмена"
              Click="OnCancelClick" />
      <Button Classes="danger"
              Content="Закрыть"
              Click="OnConfirmClick" />
    </StackPanel>
  </Grid>
</Window>
