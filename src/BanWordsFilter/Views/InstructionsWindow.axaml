<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BanWordsFilter.Views.InstructionsWindow"
        Title="Инструкция — Ban Words Filter"
        Width="700"
        Height="760"
        MinWidth="560"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="Auto,*,Auto" Margin="24,20">
    <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
      <TextBlock Text="Инструкция по настройке"
                 FontSize="22"
                 FontWeight="Bold" />
      <TextBlock Classes="muted"
                 TextWrapping="Wrap"
                 FontSize="13"
                 LineHeight="20"
                 Text="Настройка Twitch OAuth для Ban Words Filter. Прочитайте шаги по порядку — без них приложение не заработает." />
    </StackPanel>

    <Border Grid.Row="1"
            Classes="panel"
            Padding="16">
      <ScrollViewer Classes="gutter"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="StepsPanel"
                    Classes="scroll-gutter"
                    Spacing="0" />
      </ScrollViewer>
    </Border>

    <Grid Grid.Row="2"
          ColumnDefinitions="*,Auto"
          Margin="0,16,0,0">
      <StackPanel Grid.Column="0"
                  VerticalAlignment="Center"
                  Spacing="6">
        <TextBlock Text="Development by taganovv"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Classes="muted" />
        <StackPanel Orientation="Horizontal" Spacing="6">
          <Button Classes="link"
                  Content="Twitch"
                  Click="OnOpenTwitchClick" />
          <TextBlock Text="·" Classes="muted" VerticalAlignment="Center" />
          <Button Classes="link"
                  Content="GitHub"
                  Click="OnOpenGithubClick" />
          <TextBlock Text="·" Classes="muted" VerticalAlignment="Center" />
          <Button Classes="link"
                  Content="Donate"
                  Click="OnOpenDonateClick" />
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="10"
                  VerticalAlignment="Center">
        <Button Classes="secondary"
                Content="Открыть dev.twitch.tv"
                Click="OnOpenTwitchDevClick" />
        <Button Classes="primary"
                Content="Закрыть"
                Click="OnCloseClick" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
