<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BanWordsFilter.Views.UpdateDialog"
        Width="500"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="Auto,Auto" Margin="24">
    <StackPanel Grid.Row="0" Spacing="14">
      <TextBlock x:Name="TitleTextBlock"
                 FontSize="18"
                 FontWeight="Bold" />

      <TextBlock x:Name="MessageTextBlock"
                 TextWrapping="Wrap"
                 LineHeight="22" />

      <TextBlock x:Name="VersionTextBlock"
                 Classes="muted"
                 TextWrapping="Wrap" />

      <StackPanel x:Name="ProgressPanel"
                  Spacing="8"
                  IsVisible="False">
        <TextBlock x:Name="ProgressStatusText"
                   FontSize="14"
                   FontWeight="SemiBold" />
        <ProgressBar x:Name="DownloadProgressBar"
                     Classes="thin"
                     Minimum="0"
                     Maximum="100"
                     Value="0" />
        <TextBlock x:Name="ProgressDetailText"
                   Classes="muted"
                   FontSize="12" />
      </StackPanel>
    </StackPanel>

    <StackPanel x:Name="ButtonsPanel"
                Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10"
                Margin="0,20,0,0">
      <Button x:Name="SecondaryButton"
              Classes="secondary compact"
              Click="OnSecondaryClick" />
      <Button x:Name="PrimaryButton"
              Classes="primary compact"
              Click="OnPrimaryClick" />
    </StackPanel>
  </Grid>
</Window>
