<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BanWordsFilter.Views.UpdateCheckingWindow"
        Title="Ban Words Filter"
        Width="360"
        Height="160"
        CanResize="False"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen">

  <Grid Margin="24">
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="20">
      <ProgressBar IsIndeterminate="True"
                   Width="48"
                   Height="48" />
      <TextBlock Text="Проверка наличия обновлений"
                 HorizontalAlignment="Center"
                 FontSize="15"
                 FontWeight="SemiBold" />
    </StackPanel>
  </Grid>
</Window>
