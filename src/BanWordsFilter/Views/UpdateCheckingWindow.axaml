<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BanWordsFilter.Views.UpdateCheckingWindow"
        Title="Ban Words Filter"
        Width="360"
        Height="140"
        CanResize="False"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen">

  <Grid Margin="24">
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16">
      <ProgressBar Classes="thin"
                   Width="220"
                   IsIndeterminate="True" />
      <TextBlock Text="Проверка наличия обновлений"
                 HorizontalAlignment="Center"
                 FontSize="14"
                 FontWeight="SemiBold" />
    </StackPanel>
  </Grid>
</Window>
