<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BanWordsFilter.Views.AlreadyRunningDialog"
        Title="Ban Words Filter"
        Width="440"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="Auto,Auto" Margin="24">
    <StackPanel Grid.Row="0" Spacing="12">
      <TextBlock Text="Программа уже запущена"
                 FontSize="18"
                 FontWeight="Bold" />
      <TextBlock Classes="muted"
                 TextWrapping="Wrap"
                 LineHeight="22"
                 Text="Ban Words Filter уже работает. Используйте открытое окно или закройте его перед новым запуском." />
    </StackPanel>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,20,0,0">
      <Button Classes="primary compact"
              Content="Окей"
              Click="OnOkClick" />
    </StackPanel>
  </Grid>
</Window>
