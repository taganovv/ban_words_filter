<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BanWordsFilter.Views.MandatoryUpdateDialog"
        Title="Требуется обновление"
        Width="520"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="Auto,Auto" Margin="24">
    <StackPanel Grid.Row="0" Spacing="12">
      <TextBlock Text="Обновление обязательно"
                 FontSize="18"
                 FontWeight="Bold" />
      <TextBlock TextWrapping="Wrap"
                 LineHeight="22"
                 Text="Ваша версия программы сильно устарела и мы прекратили её поддержку! Пожалуйста, обновитесь до актуальной версии." />
      <TextBlock x:Name="VersionTextBlock"
                 Classes="muted"
                 TextWrapping="Wrap" />
    </StackPanel>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10"
                Margin="0,20,0,0">
      <Button Classes="secondary"
              Content="Выход"
              Click="OnExitClick" />
      <Button Classes="primary"
              Content="Обновить сейчас"
              Click="OnUpdateClick" />
    </StackPanel>
  </Grid>
</Window>
