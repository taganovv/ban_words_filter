<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BanWordsFilter.Views.ConfirmClearAllDialog"
        Title="Очистить все"
        Width="480"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="Auto,Auto" Margin="24">
    <StackPanel Grid.Row="0" Spacing="12">
      <TextBlock Text="Удалить все данные?"
                 FontSize="18"
                 FontWeight="Bold" />
      <TextBlock TextWrapping="Wrap" LineHeight="22"
                 Text="Будут очищены все поля настроек и удалены локально сохранённые данные приложения: OAuth Token, Client ID, Client Secret и другие параметры." />
      <TextBlock Classes="muted"
                 TextWrapping="Wrap"
                 Text="Если фильтр запущен, он будет остановлен. После очистки потребуется заново ввести настройки и получить OAuth Token." />
    </StackPanel>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10"
                Margin="0,20,0,0">
      <Button Classes="secondary"
              Content="Отмена"
              Click="OnCancelClick" />
      <Button Classes="danger"
              Content="Удалить всё"
              Click="OnConfirmClick" />
    </StackPanel>
  </Grid>
</Window>
