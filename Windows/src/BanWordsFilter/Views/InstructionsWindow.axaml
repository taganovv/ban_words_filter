<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BanWordsFilter.Views.InstructionsWindow"
        Title="Инструкция — Ban Words Filter"
        Width="640"
        Height="720"
        MinWidth="520"
        MinHeight="480"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="Auto,*,Auto" Margin="20">
    <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,16">
      <TextBlock Text="Как настроить приложение" FontSize="20" FontWeight="Bold" />
      <TextBlock Classes="muted" TextWrapping="Wrap"
                 Text="Пошаговая инструкция: Twitch OAuth → проверка токена → Старт перед стримом." />
    </StackPanel>

    <Border Grid.Row="1"
            Classes="panel"
            Padding="16">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <TextBlock x:Name="InstructionsText"
                   TextWrapping="Wrap"
                   FontSize="13"
                   LineHeight="22" />
      </ScrollViewer>
    </Border>

    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10"
                Margin="0,16,0,0">
      <Button Classes="secondary"
              Content="Открыть dev.twitch.tv"
              Click="OnOpenTwitchDevClick" />
      <Button Classes="primary"
              Content="Закрыть"
              Click="OnCloseClick" />
    </StackPanel>
  </Grid>
</Window>
